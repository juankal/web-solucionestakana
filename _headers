# Custom Cache-Control headers for Cloudflare Pages static site

# By default, revalidate assets and apply security headers
/*
  Cache-Control: public, max-age=0, must-revalidate
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-XSS-Protection: 1; mode=block

# Cache images for 1 year (immutable)
/images/*
  Cache-Control: public, max-age=31536000, immutable

/unnamed-5.webp
  Cache-Control: public, max-age=31536000, immutable

# Cache compiled CSS for 1 year (immutable)
/styles.css
  Cache-Control: public, max-age=31536000, immutable

# Cache JS for 1 year (immutable)
/main.js
  Cache-Control: public, max-age=31536000, immutable
