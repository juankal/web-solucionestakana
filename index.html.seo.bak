<!DOCTYPE html>
<html lang="es" class="scroll-smooth">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <!-- SEO Meta Tags -->
    <meta name="description"
        content="Soluciones Takana: Tu departamento de sistemas externo en Tacna. Especialistas en Servidores, Soporte TI, Desarrollo Web, Monitoreo Zabbix y Automatización con IA.">
    <meta name="keywords"
        content="Soporte TI, Servidores, Zabbix, Desarrollo Web, Inteligencia Artificial, Tacna, Soluciones Takana, Mantenimiento, Cloud Computing">
    <meta name="author" content="Soluciones Takana">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="https://solucionestakana.com">
    <link rel="icon" type="image/jpg" href="unnamed-5.jpg">

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://solucionestakana.com">
    <meta property="og:title" content="Soluciones Takana | Tecnología, Web & IA">
    <meta property="og:description"
        content="Infraestructura, Soporte y Tecnología. Gestión de servidores, monitoreo Zabbix, desarrollo web y automatización con IA.">
    <meta property="og:image"
        content="https://images.unsplash.com/photo-1597852074816-d933c7d2b988?q=80&w=1000&auto=format&fit=crop">

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:url" content="https://solucionestakana.com">
    <meta property="twitter:title" content="Soluciones Takana | Tecnología, Web & IA">
    <meta property="twitter:description"
        content="Infraestructura, Soporte y Tecnología. Gestión de servidores, monitoreo Zabbix, desarrollo web y automatización con IA.">
    <meta property="twitter:image"
        content="https://images.unsplash.com/photo-1597852074816-d933c7d2b988?q=80&w=1000&auto=format&fit=crop">

    <title>Soluciones Takana | Tecnología, Web & IA</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link
        href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;500;700&family=Inter:wght@300;400;600&display=swap"
        rel="stylesheet">
    <script src="https://unpkg.com/@phosphor-icons/web"></script>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        tech: ['Space Grotesk', 'sans-serif'],
                    },
                    colors: {
                        neon: {
                            cyan: '#06b6d4',
                            purple: '#8b5cf6',
                            blue: '#3b82f6',
                            green: '#10b981',
                            orange: '#f97316',
                            pink: '#ec4899'
                        }
                    },
                    animation: {
                        'float': 'float 6s ease-in-out infinite',
                        'pulse-slow': 'pulse 4s cubic-bezier(0.4, 0, 0.6, 1) infinite',
                    },
                    keyframes: {
                        float: {
                            '0%, 100%': { transform: 'translateY(0)' },
                            '50%': { transform: 'translateY(-20px)' },
                        }
                    }
                }
            }
        }
    </script>
    <style>
        body {
            background-color: #020617;
            overflow-x: hidden;
        }

        /* Efecto Glassmorphism */
        .glass {
            background: rgba(15, 23, 42, 0.7);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .glass-card {
            background: linear-gradient(145deg, rgba(30, 41, 59, 0.4) 0%, rgba(15, 23, 42, 0.6) 100%);
            backdrop-filter: blur(5px);
            border: 1px solid rgba(56, 189, 248, 0.1);
            transition: all 0.3s ease;
        }

        .glass-card:hover {
            border-color: rgba(56, 189, 248, 0.4);
            transform: translateY(-5px);
            box-shadow: 0 10px 40px -10px rgba(6, 182, 212, 0.2);
        }

        .text-gradient {
            background: linear-gradient(to right, #22d3ee, #818cf8);
            background-clip: text;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .text-gradient-orange {
            background: linear-gradient(to right, #f97316, #fbbf24);
            background-clip: text;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .hero-image-mask {
            mask-image: linear-gradient(to bottom, black 80%, transparent 100%);
            -webkit-mask-image: linear-gradient(to bottom, black 80%, transparent 100%);
        }

        /* Carrusel Styles */
        .carousel-container {
            position: relative;
            overflow: hidden;
        }

        .carousel-slide {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            opacity: 0;
            transition: opacity 1s ease-in-out;
            z-index: 1;
        }

        .carousel-slide.active {
            opacity: 1;
            z-index: 2;
        }
    </style>
</head>

<body class="text-slate-200 antialiased selection:bg-cyan-500 selection:text-white">

    <canvas id="neural-network" class="fixed top-0 left-0 w-full h-full -z-10 opacity-30 pointer-events-none"></canvas>

    <nav class="fixed w-full z-50 glass border-b border-slate-800/50 transition-all duration-300">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-20">
                <div class="flex items-center gap-3 cursor-pointer" onclick="window.scrollTo(0,0)">
                    <img src="unnamed-5.jpg" onerror="this.src='https://placehold.co/100x100/0f172a/38bdf8?text=ST'"
                        alt="Logo Soluciones Takana" class="h-14 w-auto rounded-full border border-slate-700">
                    <span class="font-tech text-2xl font-bold text-white tracking-wider">SOLUCIONES <span
                            class="text-cyan-400">TAKANA</span></span>
                </div>

                <div class="hidden lg:flex items-center space-x-8">
                    <a href="#servicios" class="text-sm font-medium hover:text-cyan-400 transition-colors">Servicios
                        TI</a>
                    <a href="#web" class="text-sm font-medium hover:text-cyan-400 transition-colors">Web & IA</a>
                    <a href="#nosotros" class="text-sm font-medium hover:text-cyan-400 transition-colors">Empresa</a>
                    <button onclick="scrollToContact()"
                        class="px-6 py-2 bg-gradient-to-r from-cyan-600 to-blue-600 hover:from-cyan-500 hover:to-blue-500 rounded-full text-white font-bold text-sm transition-all shadow-[0_0_15px_rgba(6,182,212,0.4)]">
                        Soporte & Cotización
                    </button>
                </div>

                <button class="lg:hidden text-2xl text-white" onclick="toggleMenu()">
                    <i class="ph ph-list"></i>
                </button>
            </div>
        </div>
        <div id="mobile-menu" class="hidden lg:hidden bg-slate-900 border-b border-slate-800 p-4 absolute w-full z-50">
            <a href="#servicios" class="block py-3 text-slate-300 hover:text-cyan-400 border-b border-slate-800"
                onclick="toggleMenu()">Servicios TI</a>
            <a href="#web" class="block py-3 text-slate-300 hover:text-cyan-400 border-b border-slate-800"
                onclick="toggleMenu()">Web & IA</a>
            <a href="#nosotros" class="block py-3 text-slate-300 hover:text-cyan-400 border-b border-slate-800"
                onclick="toggleMenu()">Nosotros</a>
            <button onclick="scrollToContact(); toggleMenu()"
                class="mt-4 w-full py-3 bg-cyan-600 rounded-lg text-white font-bold">Contactar Experto</button>
        </div>
    </nav>

    <section class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 overflow-hidden min-h-screen flex items-center">
        <div class="absolute top-0 right-0 w-1/2 h-1/2 bg-blue-600/10 blur-[120px] rounded-full pointer-events-none">
        </div>
        <div class="absolute bottom-0 left-0 w-1/2 h-1/2 bg-cyan-600/10 blur-[120px] rounded-full pointer-events-none">
        </div>

        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

                <div class="text-center lg:text-left animate-fade-in-up relative z-20">
                    <div
                        class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-orange-500/30 bg-orange-500/10 text-orange-300 text-xs font-bold tracking-wide uppercase mb-6">
                        <span class="w-2 h-2 rounded-full bg-orange-400 animate-pulse"></span>
                        Soporte TI & Desarrollo Digital
                    </div>

                    <h1 class="font-tech text-5xl lg:text-6xl font-bold leading-tight mb-6 text-white">
                        Infraestructura, <br />
                        Soporte y <span class="text-gradient">Tecnología</span>
                    </h1>

                    <p class="text-lg text-slate-400 mb-8 max-w-xl mx-auto lg:mx-0 leading-relaxed">
                        Somos tu departamento de sistemas externo. Desde la <strong>gestión de servidores y monitoreo
                            crítico con Zabbix</strong>, hasta el desarrollo de tu <strong>presencia web</strong> y
                        automatización con IA.
                    </p>

                    <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
                        <button onclick="scrollToContact()"
                            class="px-8 py-4 bg-white text-slate-950 font-bold rounded-full hover:bg-slate-100 transition-all flex items-center justify-center gap-2 group">
                            Solicitar Soporte
                            <i class="ph-bold ph-wrench group-hover:rotate-12 transition-transform"></i>
                        </button>
                        <a href="#servicios"
                            class="px-8 py-4 glass border border-slate-600 text-white font-bold rounded-full hover:bg-slate-800 transition-all flex items-center justify-center gap-2">
                            <i class="ph-fill ph-hard-drives text-xl"></i>
                            Ver Soluciones
                        </a>
                    </div>

                    <div
                        class="mt-10 flex flex-wrap items-center justify-center lg:justify-start gap-6 text-slate-500 text-sm font-medium">
                        <span class="flex items-center gap-1"><i class="ph-fill ph-check-circle text-cyan-500"></i>
                            Windows & Linux</span>
                        <span class="flex items-center gap-1"><i class="ph-fill ph-check-circle text-cyan-500"></i>
                            Monitoreo Zabbix</span>
                        <span class="flex items-center gap-1"><i class="ph-fill ph-check-circle text-cyan-500"></i> Web
                            & IA</span>
                    </div>
                </div>

                <div class="relative animate-float flex justify-center h-[500px]">
                    <div
                        class="absolute inset-0 bg-gradient-to-tr from-cyan-500 to-orange-600 rounded-full blur-[80px] opacity-20">
                    </div>

                    <div class="relative w-full max-w-md h-full rounded-3xl overflow-hidden shadow-2xl shadow-cyan-500/20 border border-slate-700/50 carousel-container"
                        id="hero-carousel">

                        <div class="carousel-slide active">
                            <img src="https://images.unsplash.com/photo-1597852074816-d933c7d2b988?q=80&w=1000&auto=format&fit=crop"
                                onerror="this.src='https://placehold.co/600x800/1e293b/ffffff?text=Servidores+Takana'"
                                alt="Centro de Datos y Servidores"
                                class="w-full h-full object-cover hero-image-mask opacity-90">
                            <div
                                class="absolute bottom-12 -left-4 glass p-4 rounded-xl flex items-center gap-4 animate-pulse-slow z-20 border border-slate-600/50">
                                <div
                                    class="w-10 h-10 rounded-lg bg-orange-500/20 flex items-center justify-center text-orange-400">
                                    <i class="ph-bold ph-hard-drives text-xl"></i>
                                </div>
                                <div>
                                    <div class="text-xs text-slate-400">Infraestructura</div>
                                    <div class="text-sm font-bold text-white">Servidores Seguros</div>
                                </div>
                            </div>
                            <div
                                class="absolute top-24 -right-4 glass p-4 rounded-xl flex items-center gap-4 animate-pulse-slow z-20 border border-slate-600/50 delay-700">
                                <div
                                    class="w-10 h-10 rounded-lg bg-cyan-500/20 flex items-center justify-center text-cyan-400">
                                    <i class="ph-bold ph-shield-check text-xl"></i>
                                </div>
                                <div>
                                    <div class="text-xs text-slate-400">Uptime 99.9%</div>
                                    <div class="text-sm font-bold text-white">Alta Disponibilidad</div>
                                </div>
                            </div>
                        </div>

                        <div class="carousel-slide">
                            <img src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?q=80&w=1000&auto=format&fit=crop"
                                onerror="this.src='https://placehold.co/600x800/1e293b/ffffff?text=Monitoreo+Zabbix'"
                                alt="Dashboard Monitoreo Infraestructura"
                                class="w-full h-full object-cover hero-image-mask opacity-90"
                                style="object-position: center;">
                            <div
                                class="absolute bottom-12 -left-4 glass p-4 rounded-xl flex items-center gap-4 animate-pulse-slow z-20 border border-slate-600/50">
                                <div
                                    class="w-10 h-10 rounded-lg bg-red-500/20 flex items-center justify-center text-red-400">
                                    <i class="ph-bold ph-warning text-xl"></i>
                                </div>
                                <div>
                                    <div class="text-xs text-slate-400">Alertas Zabbix</div>
                                    <div class="text-sm font-bold text-white">Control Total</div>
                                </div>
                            </div>
                            <div
                                class="absolute top-24 -right-4 glass p-4 rounded-xl flex items-center gap-4 animate-pulse-slow z-20 border border-slate-600/50 delay-700">
                                <div
                                    class="w-10 h-10 rounded-lg bg-green-500/20 flex items-center justify-center text-green-400">
                                    <i class="ph-bold ph-activity text-xl"></i>
                                </div>
                                <div>
                                    <div class="text-xs text-slate-400">Estado de Red</div>
                                    <div class="text-sm font-bold text-white">Monitoreo 24/7</div>
                                </div>
                            </div>
                        </div>

                        <div class="carousel-slide">
                            <img src="https://images.unsplash.com/photo-1531746790731-6c087fecd65a?q=80&w=1000&auto=format&fit=crop"
                                onerror="this.src='https://placehold.co/600x800/1e293b/ffffff?text=IA+Marketing'"
                                alt="Automatización IA y Marketing"
                                class="w-full h-full object-cover hero-image-mask opacity-90">
                            <div
                                class="absolute bottom-12 -left-4 glass p-4 rounded-xl flex items-center gap-4 animate-pulse-slow z-20 border border-slate-600/50">
                                <div
                                    class="w-10 h-10 rounded-lg bg-purple-500/20 flex items-center justify-center text-purple-400">
                                    <i class="ph-bold ph-robot text-xl"></i>
                                </div>
                                <div>
                                    <div class="text-xs text-slate-400">Agentes IA</div>
                                    <div class="text-sm font-bold text-white">Ventas Automáticas</div>
                                </div>
                            </div>
                            <div
                                class="absolute top-24 -right-4 glass p-4 rounded-xl flex items-center gap-4 animate-pulse-slow z-20 border border-slate-600/50 delay-700">
                                <div
                                    class="w-10 h-10 rounded-lg bg-pink-500/20 flex items-center justify-center text-pink-400">
                                    <i class="ph-bold ph-rocket-launch text-xl"></i>
                                </div>
                                <div>
                                    <div class="text-xs text-slate-400">Marketing Digital</div>
                                    <div class="text-sm font-bold text-white">Resultados Reales</div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

            </div>
        </div>
    </section>

    <section id="servicios" class="py-24 bg-slate-950 relative border-t border-slate-900">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-16">
                <h2 class="font-tech text-3xl md:text-4xl font-bold text-white mb-4">Catálogo de <span
                        class="text-cyan-400">Soluciones</span></h2>
                <p class="text-slate-400 max-w-2xl mx-auto">Unificamos el soporte técnico avanzado con el desarrollo
                    digital moderno.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">

                <div
                    class="glass-card p-8 rounded-2xl group hover:bg-slate-800/50 transition-all border-l-4 border-l-orange-500">
                    <div
                        class="w-14 h-14 rounded-xl bg-slate-800 flex items-center justify-center mb-6 group-hover:bg-orange-900/30 transition-colors">
                        <i class="ph-fill ph-hard-drives text-3xl text-orange-400"></i>
                    </div>
                    <h3 class="text-xl font-bold text-white mb-3">Servidores & Infraestructura</h3>
                    <p class="text-slate-400 text-sm leading-relaxed mb-6">
                        Planeamiento, implementación, gestión integral y <strong>monitoreo crítico</strong> de
                        servidores. Aseguramos la continuidad de tu negocio.
                    </p>
                    <ul class="space-y-2">
                        <li class="flex items-center text-sm text-slate-300 gap-2">
                            <i class="ph-bold ph-check text-orange-500"></i> Linux & Windows Server
                        </li>
                        <li class="flex items-center text-sm text-slate-300 gap-2">
                            <i class="ph-bold ph-check text-orange-500"></i> Soluciones Cloud (Azure/AWS)
                        </li>
                        <li class="flex items-center text-sm text-slate-300 gap-2">
                            <i class="ph-bold ph-check text-orange-500"></i> <strong>Monitoreo Zabbix 24/7</strong>
                        </li>
                    </ul>
                </div>

                <div class="glass-card p-8 rounded-2xl group hover:bg-slate-800/50 transition-all">
                    <div
                        class="w-14 h-14 rounded-xl bg-slate-800 flex items-center justify-center mb-6 group-hover:bg-cyan-900/30 transition-colors">
                        <i class="ph-fill ph-wrench text-3xl text-cyan-400"></i>
                    </div>
                    <h3 class="text-xl font-bold text-white mb-3">Soporte TI & Software</h3>
                    <p class="text-slate-400 text-sm leading-relaxed mb-6">
                        Asistencia técnica especializada para mantener tus equipos operativos y actualizados.
                    </p>
                    <ul class="space-y-2">
                        <li class="flex items-center text-sm text-slate-300 gap-2">
                            <i class="ph-bold ph-check text-cyan-500"></i> Soporte Informático (Helpdesk)
                        </li>
                        <li class="flex items-center text-sm text-slate-300 gap-2">
                            <i class="ph-bold ph-check text-cyan-500"></i> Mantenimiento y Formateo
                        </li>
                        <li class="flex items-center text-sm text-slate-300 gap-2">
                            <i class="ph-bold ph-check text-cyan-500"></i> Venta de Software y Licencias
                        </li>
                    </ul>
                </div>

                <div id="web"
                    class="glass-card p-8 rounded-2xl group hover:bg-slate-800/50 transition-all border-l-4 border-l-green-500">
                    <div
                        class="w-14 h-14 rounded-xl bg-slate-800 flex items-center justify-center mb-6 group-hover:bg-green-900/30 transition-colors">
                        <i class="ph-fill ph-desktop text-3xl text-green-400"></i>
                    </div>
                    <h3 class="text-xl font-bold text-white mb-3">Desarrollo Web</h3>
                    <p class="text-slate-400 text-sm leading-relaxed mb-6">
                        Sitios web profesionales optimizados para ventas y velocidad. Tu tarjeta de presentación
                        digital.
                    </p>
                    <ul class="space-y-2">
                        <li class="flex items-center text-sm text-slate-300 gap-2">
                            <i class="ph-bold ph-check text-green-500"></i> Tiendas Online (E-commerce)
                        </li>
                        <li class="flex items-center text-sm text-slate-300 gap-2">
                            <i class="ph-bold ph-check text-green-500"></i> Webs Informativas y Landing Pages
                        </li>
                    </ul>
                </div>

                <div class="glass-card p-8 rounded-2xl group hover:bg-slate-800/50 transition-all">
                    <div
                        class="w-14 h-14 rounded-xl bg-slate-800 flex items-center justify-center mb-6 group-hover:bg-cyan-900/30 transition-colors">
                        <i class="ph-fill ph-robot text-3xl text-purple-400"></i>
                    </div>
                    <h3 class="text-xl font-bold text-white mb-3">Chatbots con IA</h3>
                    <p class="text-slate-400 text-sm leading-relaxed mb-6">
                        Automatiza la atención al cliente con agentes inteligentes disponibles 24/7.
                    </p>
                </div>

                <div class="glass-card p-8 rounded-2xl group hover:bg-slate-800/50 transition-all">
                    <div
                        class="w-14 h-14 rounded-xl bg-slate-800 flex items-center justify-center mb-6 group-hover:bg-cyan-900/30 transition-colors">
                        <i class="ph-fill ph-rocket-launch text-3xl text-pink-400"></i>
                    </div>
                    <h3 class="text-xl font-bold text-white mb-3">Automatización</h3>
                    <p class="text-slate-400 text-sm leading-relaxed mb-6">
                        Conecta tus aplicaciones (CRM, Email, Excel) para eliminar tareas repetitivas.
                    </p>
                </div>

                <div class="glass-card p-8 rounded-2xl group hover:bg-slate-800/50 transition-all">
                    <div
                        class="w-14 h-14 rounded-xl bg-slate-800 flex items-center justify-center mb-6 group-hover:bg-cyan-900/30 transition-colors">
                        <i class="ph-fill ph-target text-3xl text-blue-400"></i>
                    </div>
                    <h3 class="text-xl font-bold text-white mb-3">Publicidad Digital</h3>
                    <p class="text-slate-400 text-sm leading-relaxed mb-6">
                        Campañas en Facebook y Google Ads enfocadas en captar clientes potenciales.
                    </p>
                </div>

            </div>
        </div>
    </section>

    <section id="nosotros" class="py-24 relative">
        <div class="absolute inset-0 bg-gradient-to-r from-slate-900 to-slate-950 skew-y-3 transform -z-10"></div>
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
                <div>
                    <h2 class="font-tech text-3xl md:text-4xl font-bold text-white mb-6">Ingeniería y Marketing <br>
                        bajo <span class="text-gradient-orange">un mismo techo</span></h2>
                    <p class="text-slate-400 mb-6 leading-relaxed">
                        En <strong>Soluciones Takana</strong> no solo diseñamos webs bonitas. Tenemos el conocimiento
                        técnico profundo de un departamento de sistemas.
                    </p>
                    <p class="text-slate-400 mb-8 leading-relaxed">
                        Entendemos de servidores, redes, seguridad informática y <strong>monitoreo de infraestructura
                            crítica</strong>. Esto nos permite ofrecerte soluciones integrales: desde instalar y vigilar
                        el servidor de tu oficina con <strong>Zabbix</strong> hasta crear la tienda online que venderá
                        tus productos al mundo.
                    </p>
                    <div class="grid grid-cols-2 gap-6">
                        <div>
                            <div class="text-3xl font-bold text-white mb-1">360°</div>
                            <div class="text-xs text-slate-500 uppercase tracking-wider">Cobertura Tecnológica</div>
                        </div>
                        <div>
                            <div class="text-3xl font-bold text-white mb-1">100%</div>
                            <div class="text-xs text-slate-500 uppercase tracking-wider">Soporte Garantizado</div>
                        </div>
                    </div>
                </div>
                <div class="relative">
                    <div
                        class="absolute -inset-4 bg-gradient-to-r from-orange-500 to-cyan-500 rounded-2xl opacity-20 blur-lg">
                    </div>
                    <div class="relative glass p-8 rounded-2xl border border-slate-700">
                        <div class="flex items-start gap-4 mb-6">
                            <div class="w-10 h-10 rounded-full bg-slate-700 flex items-center justify-center text-xl">
                                🛠️</div>
                            <div>
                                <h4 class="text-white font-bold">Experiencia Técnica</h4>
                                <p class="text-sm text-slate-400">Administración de Sistemas y Redes.</p>
                            </div>
                        </div>
                        <div class="flex items-start gap-4 mb-6">
                            <div class="w-10 h-10 rounded-full bg-slate-700 flex items-center justify-center text-xl">📟
                            </div>
                            <div>
                                <h4 class="text-white font-bold">Monitoreo Crítico</h4>
                                <p class="text-sm text-slate-400">Vigilancia 24/7 con Zabbix y alertas.</p>
                            </div>
                        </div>
                        <div class="flex items-start gap-4">
                            <div class="w-10 h-10 rounded-full bg-slate-700 flex items-center justify-center text-xl">🌐
                            </div>
                            <div>
                                <h4 class="text-white font-bold">Presencia Digital</h4>
                                <p class="text-sm text-slate-400">Estrategias de venta online automatizadas.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="contacto" class="py-24 relative">
        <div class="absolute inset-0 bg-gradient-to-b from-slate-950 to-slate-900"></div>
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
            <div class="glass rounded-3xl p-8 md:p-12 border border-slate-700 shadow-2xl">
                <div class="text-center mb-10">
                    <h2 class="font-tech text-3xl font-bold text-white mb-2">Hablemos de tu Proyecto</h2>
                    <p class="text-slate-400">Ya sea soporte técnico, monitoreo o desarrollo web, estamos listos.</p>
                </div>

                <form action="https://formspree.io/f/xpqdbjpq" method="POST" class="space-y-6">
                    <input type="hidden" name="_next" value="index.html">

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label
                                class="block text-xs uppercase tracking-wider text-slate-500 font-bold mb-2">Nombre</label>
                            <input type="text" name="nombre"
                                class="w-full bg-slate-900/50 border border-slate-700 rounded-lg px-4 py-3 text-white focus:border-cyan-500 focus:outline-none transition-colors"
                                placeholder="Tu nombre" required>
                        </div>
                        <div>
                            <label
                                class="block text-xs uppercase tracking-wider text-slate-500 font-bold mb-2">Empresa</label>
                            <input type="text" name="empresa"
                                class="w-full bg-slate-900/50 border border-slate-700 rounded-lg px-4 py-3 text-white focus:border-cyan-500 focus:outline-none transition-colors"
                                placeholder="Nombre de tu negocio" required>
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs uppercase tracking-wider text-slate-500 font-bold mb-2">Teléfono /
                            WhatsApp</label>
                        <input type="tel" name="telefono"
                            class="w-full bg-slate-900/50 border border-slate-700 rounded-lg px-4 py-3 text-white focus:border-cyan-500 focus:outline-none transition-colors"
                            placeholder="+51 999 999 999" required>
                    </div>
                    <div>
                        <label class="block text-xs uppercase tracking-wider text-slate-500 font-bold mb-2">¿En qué
                            podemos ayudarte?</label>
                        <select name="servicio"
                            class="w-full bg-slate-900/50 border border-slate-700 rounded-lg px-4 py-3 text-slate-300 focus:border-cyan-500 focus:outline-none transition-colors">
                            <option>Soporte Técnico / Mantenimiento</option>
                            <option>Servidores & Monitoreo Zabbix</option>
                            <option>Venta de Software / Licencias</option>
                            <option>Página Web / Tienda Online</option>
                            <option>Chatbots & Automatización</option>
                        </select>
                    </div>
                    <button type="submit"
                        class="w-full py-4 bg-gradient-to-r from-cyan-600 to-blue-600 rounded-lg text-white font-bold text-lg hover:shadow-lg hover:shadow-cyan-500/25 transition-all transform hover:-translate-y-1">
                        Solicitar Cotización
                    </button>
                </form>
            </div>
        </div>
    </section>

    <footer class="bg-slate-950 border-t border-slate-900 pt-16 pb-8">
        <div
            class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row justify-between items-center gap-6">
            <div class="flex items-center gap-3">
                <img src="unnamed-5.jpg" onerror="this.src='https://placehold.co/100x100/0f172a/38bdf8?text=ST'"
                    alt="Logo Soluciones Takana" class="h-12 w-auto rounded-full">
                <span class="font-tech font-bold text-white">SOLUCIONES TAKANA</span>
            </div>
            <p class="text-slate-500 text-sm">© 2026 Soluciones Takana. Tacna - Perú. JCAA</p>
            <div class="flex gap-4 text-slate-400">
                <a href="#" class="hover:text-cyan-400"><i class="ph-fill ph-linkedin-logo text-xl"></i></a>
                <a href="https://www.facebook.com/solucionestakana" class="hover:text-cyan-400"><i
                        class="ph-fill ph-facebook-logo text-xl"></i></a>
                <a href="https://www.instagram.com/solucionestakana" class="hover:text-cyan-400"><i
                        class="ph-fill ph-instagram-logo text-xl"></i></a>
            </div>
        </div>
    </footer>

    <script>
        // Mobile Menu Toggle
        function toggleMenu() {
            const menu = document.getElementById('mobile-menu');
            menu.classList.toggle('hidden');
        }

        function scrollToContact() {
            document.getElementById('contacto').scrollIntoView({ behavior: 'smooth' });
        }

        // Particle Network Animation (Vanilla JS)
        const canvas = document.getElementById('neural-network');
        const ctx = canvas.getContext('2d');
        let width, height, particles;

        function resize() {
            width = window.innerWidth;
            height = window.innerHeight;
            canvas.width = width;
            canvas.height = height;
            initParticles();
        }

        function initParticles() {
            particles = [];
            const count = Math.floor(width / 15); // Density
            for (let i = 0; i < count; i++) {
                particles.push({
                    x: Math.random() * width,
                    y: Math.random() * height,
                    vx: (Math.random() - 0.5) * 0.5,
                    vy: (Math.random() - 0.5) * 0.5,
                    size: Math.random() * 2
                });
            }
        }

        function draw() {
            ctx.clearRect(0, 0, width, height);
            ctx.fillStyle = '#38bdf8'; // Cyan-400
            ctx.strokeStyle = 'rgba(56, 189, 248, 0.15)';

            for (let i = 0; i < particles.length; i++) {
                let p = particles[i];
                p.x += p.vx;
                p.y += p.vy;

                if (p.x < 0 || p.x > width) p.vx *= -1;
                if (p.y < 0 || p.y > height) p.vy *= -1;

                ctx.beginPath();
                ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
                ctx.fill();

                for (let j = i + 1; j < particles.length; j++) {
                    let p2 = particles[j];
                    let dx = p.x - p2.x;
                    let dy = p.y - p2.y;
                    let dist = Math.sqrt(dx * dx + dy * dy);

                    if (dist < 120) {
                        ctx.lineWidth = 1 - (dist / 120);
                        ctx.beginPath();
                        ctx.moveTo(p.x, p.y);
                        ctx.lineTo(p2.x, p2.y);
                        ctx.stroke();
                    }
                }
            }
            requestAnimationFrame(draw);
        }

        window.addEventListener('resize', resize);
        resize();
        draw();

        // Carousel Script
        const slides = document.querySelectorAll('.carousel-slide');
        let currentSlide = 0;
        const slideInterval = 5000; // Cambio cada 5 segundos

        function nextSlide() {
            slides[currentSlide].classList.remove('active');
            currentSlide = (currentSlide + 1) % slides.length;
            slides[currentSlide].classList.add('active');
        }

        setInterval(nextSlide, slideInterval);
    </script>
</body>

</html>